{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rjp.local/protocol/schemas/domain_spec.schema.json",
  "title": "DomainSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "domain_id",
    "version",
    "status",
    "name",
    "summary",
    "subject_scope",
    "target_scope",
    "window_policy",
    "judgment_outcomes",
    "evidence_policy",
    "evaluation_spec",
    "model_policy",
    "equivalence_profile",
    "revision_policy",
    "policy_hashes"
  ],
  "properties": {
    "schema_version": {
      "const": "rjp.domain_spec.v1"
    },
    "domain_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "subject_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_type",
        "allowed_subject_networks"
      ],
      "properties": {
        "subject_type": {
          "type": "string",
          "enum": [
            "wallet",
            "contract",
            "wallet_contract_pair",
            "wallet_protocol_pair"
          ]
        },
        "allowed_subject_networks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "target_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_type",
        "target_network",
        "target_contracts",
        "target_protocols",
        "target_context_keys"
      ],
      "properties": {
        "target_type": {
          "type": "string",
          "enum": [
            "wallet",
            "contract",
            "wallet_contract_pair",
            "wallet_protocol_pair"
          ]
        },
        "target_network": {
          "type": "string",
          "minLength": 1
        },
        "target_contracts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^0x[a-f0-9]{40}$"
          }
        },
        "target_protocols": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "target_context_keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "window_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "default_window_blocks",
        "max_window_blocks",
        "freshness_window_blocks"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "rolling",
            "fixed",
            "pinned"
          ]
        },
        "default_window_blocks": {
          "type": "integer",
          "minimum": 1
        },
        "max_window_blocks": {
          "type": "integer",
          "minimum": 1
        },
        "freshness_window_blocks": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "judgment_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "admissible_item_kinds",
        "selection_rule",
        "ordering_rule",
        "canonicalization_rule"
      ],
      "properties": {
        "policy_id": {
          "type": "string",
          "minLength": 1
        },
        "admissible_item_kinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "selection_rule": {
          "type": "string",
          "minLength": 1
        },
        "ordering_rule": {
          "type": "string",
          "minLength": 1
        },
        "canonicalization_rule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evaluation_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evaluation_spec_id",
        "claim_type",
        "rubric_summary",
        "required_features",
        "output_payload_fields"
      ],
      "properties": {
        "evaluation_spec_id": {
          "type": "string",
          "minLength": 1
        },
        "claim_type": {
          "type": "string",
          "minLength": 1
        },
        "rubric_summary": {
          "type": "string",
          "minLength": 1
        },
        "required_features": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "output_payload_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "model_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "model_family",
        "output_schema_version",
        "confidence_tolerance_ppm"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "deterministic",
            "llm",
            "hybrid"
          ]
        },
        "model_family": {
          "type": "string",
          "minLength": 1
        },
        "output_schema_version": {
          "type": "string",
          "minLength": 1
        },
        "confidence_tolerance_ppm": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        }
      }
    },
    "equivalence_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "outcome_match_required",
        "confidence_tolerance_ppm",
        "payload_hash_required"
      ],
      "properties": {
        "profile_id": {
          "type": "string",
          "minLength": 1
        },
        "outcome_match_required": {
          "type": "boolean"
        },
        "confidence_tolerance_ppm": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "payload_hash_required": {
          "type": "boolean"
        }
      }
    },
    "revision_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "revision_policy_id",
        "parent_link_required",
        "supersedes_prior",
        "recency_basis"
      ],
      "properties": {
        "revision_policy_id": {
          "type": "string",
          "minLength": 1
        },
        "parent_link_required": {
          "type": "boolean"
        },
        "supersedes_prior": {
          "type": "boolean"
        },
        "recency_basis": {
          "type": "string",
          "enum": [
            "source_window_end_block",
            "evaluated_at"
          ]
        }
      }
    },
    "policy_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain_spec_hash",
        "evidence_policy_hash",
        "evaluation_spec_hash",
        "model_policy_hash",
        "equivalence_profile_hash",
        "revision_policy_hash"
      ],
      "properties": {
        "domain_spec_hash": {
          "type": "string",
          "pattern": "^0x[a-f0-9]{64}$"
        },
        "evidence_policy_hash": {
          "type": "string",
          "pattern": "^0x[a-f0-9]{64}$"
        },
        "evaluation_spec_hash": {
          "type": "string",
          "pattern": "^0x[a-f0-9]{64}$"
        },
        "model_policy_hash": {
          "type": "string",
          "pattern": "^0x[a-f0-9]{64}$"
        },
        "equivalence_profile_hash": {
          "type": "string",
          "pattern": "^0x[a-f0-9]{64}$"
        },
        "revision_policy_hash": {
          "type": "string",
          "pattern": "^0x[a-f0-9]{64}$"
        }
      }
    }
  }
}
